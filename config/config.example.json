{
  "app_name": "RepoScan",
  "shortcut_name": "RepoScan",
  "default_repository_path": "~/Documents/repos",
  "max_scan_depth": 3,
  "fetch_timeout_seconds": 30,
  "gui_window_size": "1400x1000",
  "show_empty_folders": true,

  "_comment": "Ajustez ces chemins selon votre environnement:",
  "_examples": {
    "linux_ubuntu": "~/Documents/repos ou /home/username/projets",
    "linux_arch": "~/Code ou /home/username/git",
    "windows": "C:\\Users\\username\\Documents\\repositories",
    "macos": "/Users/username/Developer/repos"
  },

  "windows": {
    "distro": "Ubuntu",
    "linux_project_path": "~/www/repo-scan"
  }
}
