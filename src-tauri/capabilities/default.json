{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions for RepoScan",
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "opener:allow-open-url",
    "opener:allow-reveal-item-in-dir",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-read-text",
    "os:allow-os-type",
    "os:allow-locale",
    "log:allow-log"
  ]
}
