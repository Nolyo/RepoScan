{
  "productName": "RepoScan",
  "version": "0.1.0-beta.1",
  "identifier": "dev.reposcan.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RepoScan",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local Git repositories dashboard",
    "publisher": "RepoScan",
    "linux": {
      "deb": {
        "depends": ["git"]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM4MTM0QUUyNTQzMDI5RDgKUldUWUtUQlU0a29UeUlvTTMzQ0l0cTkyRnFnU0F4UEIrNTNURnBaRG1HeGRUUFcxZ3BKZ0xzNkkK",
      "endpoints": [
        "https://github.com/Nolyo/RepoScan/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
